# ── Server-side (never exposed to the browser) ──────────────────────────────

# Base URL of the Ory Hydra Admin API used by Next.js API routes.
HYDRA_ADMIN_URL=http://localhost:4445

# Base URL of the Ory Hydra Public API used by Next.js API routes (token issuance).
HYDRA_PUBLIC_URL=http://localhost:4444

# System secret used by Ory Hydra to sign/encrypt tokens and cookies.
# Must be at least 16 characters. Change this to a random value before going to production.
# Generate one with: openssl rand -hex 32
#
# ⚠️  IMPORTANT: If you change this value after Hydra has already created OAuth
# clients, Hydra will fail to verify those clients' secrets (they were encrypted
# with the old key).  When changing SECRETS_SYSTEM you MUST wipe and recreate
# the Hydra database volume:
#   docker compose down -v && docker compose up -d
SECRETS_SYSTEM=REPLACE-WITH-openssl-rand-hex-32

# ── Build-time / browser-safe ────────────────────────────────────────────────
# Displayed in the sidebar so users know which Hydra instance the UI talks to.
# NOTE: Next.js inlines NEXT_PUBLIC_* variables at build time; if you change
# this value you must rebuild the application.
NEXT_PUBLIC_HYDRA_ADMIN_URL=http://localhost:4445
